# ============================================================
# .env.example — Template biến môi trường cho Docker
#
# Sao chép file này thành .env rồi điền giá trị thực:
#   copy .env.example .env
#
# KHÔNG commit file .env lên Git!
# ============================================================

# ── MySQL ────────────────────────────────────────────────────
DB_USER=root
DB_PASSWORD=sapassword
DB_NAME=vlxd_db

# ── Backend ──────────────────────────────────────────────────
# Secret dùng xác thực webhook từ n8n
WEBHOOK_SECRET=vlxd-secret-2026

# ── Frontend ─────────────────────────────────────────────────
# Google Maps API Key (lấy từ Google Cloud Console)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── ngrok ────────────────────────────────────────────────────
# BẮT BUỘC: Đăng ký tài khoản miễn phí tại https://ngrok.com
# Vào Dashboard → Your Authtoken → copy vào đây
NGROK_AUTHTOKEN=your_ngrok_authtoken_here

# ── n8n (tùy chọn) ───────────────────────────────────────────
# Sau khi ngrok chạy, xem URL thực tại http://localhost:4040
# rồi cập nhật biến này để webhook hoạt động đúng
# N8N_WEBHOOK_URL=https://xxxx-xxx-xxx.ngrok-free.app/
