# ============================================================
# server/.env — Biến môi trường (KHÔNG commit file này lên Git)
# ============================================================

# Cổng Express server lắng nghe
PORT=5000

# Kết nối MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=sapassword
DB_NAME=vlxd_db
DB_PORT=3307

# Secret để n8n xác thực khi gọi /api/orders/:id/confirm
# Phải khớp với header x-webhook-secret trong n8n HTTP Request node
WEBHOOK_SECRET=vlxd-secret-2026
